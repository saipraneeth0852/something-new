# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
#  Uncomment the following line in case you need and you don't have the release build type files in your app
# release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
# Keystore files used for signing
*.jks
*.keystore
# Except the public debug keystore
!/debug.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Fragments for the preview in the layout editor
*.layout

# Version control
.svn/

# OS-specific files
.DS_Store
Thumbs.db

# User-specific configurations
*.swp
*.swo
*~

# API Keys & Secrets (NEVER commit these)
.env
secrets.xml
google-services.json

# CI/CD artifacts
*.log
*.txt

# Kotlin/Native
*.klib
*.knm

# Android Profiling
*.hprof

# Lint
lint-baseline.xml

# Firebase config (contains API keys)
app/google-services.json
